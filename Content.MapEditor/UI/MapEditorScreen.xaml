<editor:MapEditorScreen xmlns="https://spacestation14.io"
    xmlns:editor="clr-namespace:Content.MapEditor.UI"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client">

    <LayoutContainer Name="RootLayout" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Name="MainLayout" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">

            <!-- MenuBar placeholder: populated in code-behind -->
            <BoxContainer Name="MenuBarContainer" Orientation="Horizontal"
                          HorizontalExpand="True" MinHeight="24" />

            <!-- Grid tab bar -->
            <PanelContainer Name="GridTabBarPanel" HorizontalExpand="True" MinHeight="28">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#1E1E1EDD" />
                </PanelContainer.PanelOverride>
                <BoxContainer Name="GridTabBar" Orientation="Horizontal" Margin="4 2" />
            </PanelContainer>

            <!-- Middle row: Toolbar | Viewport | Palette -->
            <BoxContainer Name="MiddleRow" Orientation="Horizontal" VerticalExpand="True" HorizontalExpand="True">

                <!-- Left toolbar -->
                <PanelContainer Name="ToolbarPanel" MinWidth="36">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat BackgroundColor="#2A2A2ADD" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Name="ToolbarButtons" Orientation="Vertical" Margin="2 4" />
                </PanelContainer>

                <!-- Main viewport fills remaining space -->
                <LayoutContainer Name="ViewportContainer" VerticalExpand="True" HorizontalExpand="True">
                    <controls:MainViewport Name="MainViewport" Access="Public" />
                </LayoutContainer>

                <!-- Right tile palette -->
                <PanelContainer Name="PalettePanel" MinWidth="250" MaxWidth="250">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat BackgroundColor="#2A2A2ADD" />
                    </PanelContainer.PanelOverride>
                    <BoxContainer Name="PaletteLayout" Orientation="Vertical" Margin="4">
                        <Label Text="Tiles" Margin="0 0 0 4" />
                        <LineEdit Name="TileSearchEdit" HorizontalExpand="True" PlaceHolder="Search tiles..." Margin="0 0 0 4" />
                        <ItemList Name="TileList" VerticalExpand="True" HorizontalExpand="True" />
                    </BoxContainer>
                </PanelContainer>

            </BoxContainer>

            <!-- Status bar at bottom -->
            <PanelContainer Name="StatusBarPanel" HorizontalExpand="True">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#222222DD" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" Margin="4 2">
                    <Label Name="StatusCoords" Text="(0, 0)" MinWidth="120" />
                    <Label Name="StatusZoom" Text="Zoom: 1.0x" MinWidth="100" />
                    <Label Name="StatusTool" Text="Tool: Paint" MinWidth="100" />
                    <Label Name="StatusInfo" Text="No map loaded" HorizontalExpand="True" />
                </BoxContainer>
            </PanelContainer>

        </BoxContainer>
    </LayoutContainer>
</editor:MapEditorScreen>
