<controls:FancyWindow xmlns="https://spacestation14.io"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
            Title="{Loc 'cable-relay-menu-title'}"
            Resizable="False"
            MinSize="320 200">
    <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="12">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Text="{Loc 'cable-relay-menu-relay'}" VerticalAlignment="Center" />
            <Control HorizontalExpand="True" MinSize="20 0" />
            <controls:SwitchButton Name="PowerSwitch" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </BoxContainer>
        <RichTextLabel Name="StatusLabel" HorizontalExpand="True" />
        <PanelContainer StyleClasses="LowDivider" />
        <Label Text="{Loc 'cable-relay-menu-affected'}" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="8">
            <Button Name="ButtonHV" Text="{Loc 'cable-relay-menu-hv'}" ToggleMode="True" HorizontalExpand="True" />
            <Button Name="ButtonMV" Text="{Loc 'cable-relay-menu-mv'}" ToggleMode="True" HorizontalExpand="True" />
            <Button Name="ButtonLV" Text="{Loc 'cable-relay-menu-lv'}" ToggleMode="True" HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
