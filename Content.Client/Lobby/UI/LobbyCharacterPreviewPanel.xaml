<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:ui="clr-namespace:Content.Client.Lobby.UI"
    xmlns:profile="clr-namespace:Content.Client.Lobby.UI.ProfileEditorControls">
    <BoxContainer Name="VBox" Orientation="Vertical">

        <!-- Header -->
        <controls:NanoHeading Name="Header" Text="{Loc 'lobby-character-preview-panel-header'}" />

        <!-- This is the main bit, only shows once we have preferences from the server -->
        <BoxContainer Name="Loaded" Orientation="Vertical"
                      Visible="False"
                      SeparationOverride="8">
            <!-- Character summary text, character setup button, and character preview -->
            <BoxContainer Orientation="Horizontal" Align="Center" SeparationOverride="30">
                <BoxContainer Orientation="Vertical" Align="Center" SeparationOverride="25">
                    <Label Name="Summary" />
                    <Button Name="CharacterSetup" Text="{Loc 'lobby-character-preview-panel-character-setup-button'}"
                            HorizontalAlignment="Center"/>
                </BoxContainer>
                <profile:ProfilePreviewSpriteView Name="ProfilePreviewSpriteView"
                                                  OverrideDirection="South"
                                                  Scale="3 3"
                                                  MaxSize="96 96"
                                                  Stretch="Fill"
                                                  HorizontalAlignment="Center"
                                                  Access="Public" />
            </BoxContainer>

            <!-- Where we show ALL the jobs, separated into priorities -->
            <Collapsible StyleIdentifier="lobbyCollapsibleSubsection" BodyVisible="True">
                <CollapsibleHeading Title="{Loc 'lobby-character-preview-panel-jobs-heading'}"/>
                <CollapsibleBody>
                    <PanelContainer StyleClasses="BackgroundPanelDark">
                        <BoxContainer VerticalExpand="True"
                                      HorizontalExpand="True"
                                      HorizontalAlignment="Stretch"
                                      SeparationOverride="6"
                                      Margin="5">

                            <!-- Jobs with "Never" priority -->
                            <ui:DraggableJobTarget Name="NeverBox"
                                                   Priority="Never"
                                                   HorizontalExpand="True"
                                                   SizeFlagsStretchRatio="1" />

                            <!-- Vertical rule -->
                            <PanelContainer MinSize="2 0" StyleClasses="HighDivider"/>

                            <!-- Jobs with "Low" priority -->
                            <ui:DraggableJobTarget Name="LowBox"
                                                   Priority="Low"
                                                   HorizontalExpand="True"
                                                   SizeFlagsStretchRatio="1" />

                            <!-- Vertical rule -->
                            <PanelContainer MinSize="2 0" StyleClasses="HighDivider"/>

                            <!-- Jobs with "Medium" priority -->
                            <ui:DraggableJobTarget Name="MediumBox"
                                                   Priority="Medium"
                                                   HorizontalExpand="True"
                                                   SizeFlagsStretchRatio="1" />

                            <!-- Vertical rule -->
                            <PanelContainer MinSize="2 0" StyleClasses="HighDivider"/>

                            <!-- THE job with "HIGH" priority -->
                            <ui:DraggableJobTarget Name="HighBox" Priority="High" />

                        </BoxContainer>
                    </PanelContainer> <!-- End job grids -->
                </CollapsibleBody>
            </Collapsible>
        </BoxContainer>
        <Label Name="Unloaded" Text="{Loc 'lobby-character-preview-panel-unloaded-preferences-label'}"/>
    </BoxContainer>
</Control>
