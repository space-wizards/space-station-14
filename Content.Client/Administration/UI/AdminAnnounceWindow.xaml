<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc admin-announce-title}"
    MinWidth="650"
    MinHeight="350">
    <BoxContainer Orientation="Vertical" Margin="4">
        <GridContainer Columns="2" HorizontalExpand="True" Margin="0,0,0,4">
            <LineEdit Name="Announcer" 
                      Access="Public" 
                      PlaceHolder="{Loc admin-announce-announcer-placeholder}" 
                      Text="{Loc admin-announce-announcer-default}" 
                      HorizontalExpand="True" 
                      Margin="2" />
            <LineEdit Name="Sender" 
                      Access="Public" 
                      PlaceHolder="{Loc admin-announce-sender-placeholder}" 
                      Text="{Loc admin-announce-sender-default}" 
                      HorizontalExpand="True" 
                      Margin="2" />
        </GridContainer>
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0,0,0,4">
            <BoxContainer Orientation="Horizontal" Margin="2">
                <Button Name="ColorPreview" Access="Public" Text=" " MinSize="30, 30" Margin="0,0,4,0" />
                <LineEdit Name="ColorHex" Access="Public" MinWidth="135" /> 
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="2">
                <LineEdit Name="SoundPath" 
                          Access="Public" 
                          PlaceHolder="{Loc admin-announce-sound-placeholder}" 
                          HorizontalExpand="True" />
                <Button Name="PlayAudio" Access="Public" Text="▶" Margin="4,0,0,0" MinWidth="35" />
            </BoxContainer>
        </BoxContainer>
        <TextEdit Name="Announcement" Access="Public" VerticalExpand="True" MinHeight="150" Margin="0,4" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0,4,0,0">
            <CheckBox Name="KeepWindowOpen" Access="Public" Text="{Loc admin-announce-keep-open}" VerticalAlignment="Center" />
            <Control HorizontalExpand="True" /> 
            <Button Name="AnnounceButton" Access="Public" Disabled="True" Text="{Loc admin-announce-button}" MinWidth="150" />
            <OptionButton Name="AnnounceMethod" Access="Public" MinWidth="150" Margin="4,0,0,0"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
