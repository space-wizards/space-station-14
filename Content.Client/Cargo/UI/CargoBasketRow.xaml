<BoxContainer xmlns="https://spacestation14.io"
    HorizontalExpand="True">
    <PanelContainer HorizontalExpand="True">

        <!-- Icon & Name -->
        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      Margin="4 0">

            <TextureRect Name="Icon"
                         Access="Public"
                         MinSize="32 32"
                         RectClipContent="True" />

            <Label Name="ProductName"
                   Access="Public"
                   HorizontalExpand="True"
                   ClipText="True" />
        </BoxContainer>
    </PanelContainer>
    <SpinBox Name="Amount"
        Access="Public"
        MinWidth="100"
        />
    <BoxContainer
        Orientation="Horizontal"
        HorizontalAlignment="Right"
        MinWidth="60">
        <Control HorizontalExpand="True" />
        <Label Name="PointCost"
            Access="Public"
            HorizontalAlignment="Right"
            Align="Right" />
        <Control MinWidth="5" />
    </BoxContainer>
    <Button Name="Remove"
            Text ="{Loc 'cargo-console-menu-cart-remove'}"
            Access="Public"
            HorizontalAlignment="Right"/>
</BoxContainer>
