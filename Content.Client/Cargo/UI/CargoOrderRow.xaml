<PanelContainer
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    HorizontalExpand="True"
    StyleClasses="BackgroundPanel">

    <!--  Main Container  -->
    <BoxContainer
        Margin="-14,-2"
        HorizontalExpand="True"
        Orientation="Vertical">

        <BoxContainer Orientation="Vertical">
            <PanelContainer StyleClasses="WindowHeadingBackground" />

            <BoxContainer Margin="5 0 15 3">
                <Label
                    Name="Title"
                    MaxHeight="20"
                    Access="Public"
                    StyleClasses="LabelKeyText" />
                <Control HorizontalExpand="True" />
                <RichTextLabel
                        Name="Requester"
                        Access="Public"
                        MaxHeight="20"
                        HorizontalAlignment="Right"/>
            </BoxContainer>
            <PanelContainer
                Name="Stride"
                Access="Public"
                StyleClasses="LowDivider" />
        </BoxContainer>
        <!--  Products  -->
        <BoxContainer
            Name="Products"
            Access="Public"
            HorizontalExpand="True"
            Orientation="Vertical"
            VerticalExpand="True"
            Margin="0 2 0 0">
            <!--  Products are added here by code  -->
        </BoxContainer>
        <BoxContainer
            VerticalAlignment="Bottom"
            HorizontalExpand="True"
            Orientation="Vertical"
            Margin="12 2 15 0">
            <BoxContainer HorizontalExpand="True" Orientation="Horizontal">
                <Label
                    HorizontalAlignment="Left"
                    Access="Public"
                    Text="{Loc 'cargo-console-menu-cart-container-cost-label'}" />
                <Control HorizontalExpand="True" />
                <Label
                    Name="ContainerCost"
                    HorizontalAlignment="Right"
                    Access="Public"
                    Align="Right"
                    Text="0" />
            </BoxContainer>
            <BoxContainer HorizontalExpand="True" Orientation="Horizontal">
                <Label
                    HorizontalAlignment="Left"
                    Access="Public"
                    Text="{Loc 'cargo-console-menu-cart-total-label'}" />
                <Control HorizontalExpand="True" />
                <Label
                    Name="BasketTotal"
                    HorizontalAlignment="Right"
                    Access="Public"
                    Align="Right"
                    Text="0" />
            </BoxContainer>
        </BoxContainer>
        <PanelContainer
            Name="StrideStride"
            Access="Public"
            StyleClasses="LowDivider" />
        <BoxContainer
            VerticalAlignment="Bottom"
            HorizontalExpand="True"
            Orientation="Vertical"
            Margin="12 0 15 0">
            <BoxContainer HorizontalExpand="True" Orientation="Horizontal">
                <RichTextLabel
                    Name="Description"
                    Access="Public"
                    HorizontalExpand="True"
                    StyleClasses="LabelSubText"
                    VerticalExpand="True" />
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Name="Buttons" Orientation="Vertical" Access="Public">
            <PanelContainer StyleClasses="LowDivider" />
            <!--  Buttons  -->
            <BoxContainer Margin="3">
                <Button
                    Name="Approve"
                    Access="Public"
                    HorizontalExpand="True"
                    StyleClasses="OpenRight"
                    Text="{Loc 'cargo-console-menu-order-row-button-approve'}" />

                <Button
                    Name="Cancel"
                    Access="Public"
                    HorizontalExpand="True"
                    StyleClasses="OpenLeft"
                    Text="{Loc 'cargo-console-menu-order-row-button-cancel'}" />
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</PanelContainer>
