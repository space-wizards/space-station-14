<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc 'cargo-console-order-menu-title'}"
    MinSize="460 261">
    <BoxContainer Orientation="Vertical">
        <GridContainer Columns="2">
            <Label StyleClasses="LabelKeyText" Text="{Loc 'cargo-console-order-menu-product-label'}" />

            <Label Name="ProductName" Access="Public" />

            <Label StyleClasses="LabelKeyText" Text="{Loc 'cargo-console-order-menu-description-label'}" />

            <RichTextLabel
                Name="Description"
                MaxWidth="460"
                Access="Public"
                HorizontalExpand="True" />

            <Label StyleClasses="LabelKeyText" Text="{Loc 'cargo-console-order-menu-cost-label'}" />

            <Label Name="PointCost" Access="Public" />

            <Label StyleClasses="LabelKeyText" Text="{Loc 'cargo-console-order-menu-amount-label'}" />

            <SpinBox
                Name="Amount"
                Access="Public"
                HorizontalExpand="True"
                Value="1" />
        </GridContainer>
        <Control VerticalExpand="True" />
        <PanelContainer Margin="0,6,0,2" StyleClasses="LowDivider" />
        <Button
            Name="SubmitButton"
            VerticalAlignment="Bottom"
            Access="Public"
            Text="{Loc 'cargo-console-order-menu-submit-button'}" />
    </BoxContainer>
</DefaultWindow>
