<ContainerButton HorizontalExpand="True" MinHeight="60" Margin="4"
                 xmlns:pda="clr-namespace:Content.Client.PDA"
                 xmlns="https://spacestation14.io">
    <PanelContainer Name="Panel"/>
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Vertical" VerticalExpand="True" MinWidth="60">
            <AnimatedTextureRect HorizontalAlignment="Center" VerticalAlignment="Center" VerticalExpand="True" Name="Icon" />
        </BoxContainer>
        <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
            <Label Name="ProgramName" VerticalExpand="True" />
            <BoxContainer HorizontalExpand="True" SetHeight="28" Margin="0 0 4 4">
                <BoxContainer HorizontalExpand="True" />
                <Button Name="InstallButton" Visible="False" SetWidth="90" HorizontalAlignment="Right" VerticalExpand="True"></Button>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</ContainerButton>
