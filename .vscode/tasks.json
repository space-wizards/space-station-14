{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "detail": "Builds the game. This requires Just.",
            "command": "just",
            "type": "shell",
            "args": [
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-yaml-linter",
            "detail": "Builds the YAML Linter. This requires Just.",
            "command": "just",
            "type": "process",
            "args": [
                "build-yaml-linter"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "just",
            "detail": "Runs all unit tests. This requires Just.",
            "type": "shell",
            "args": [
                "run-tests"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "integration-test",
            "detail": "Runs all integration tests. This requires Just. These tests take a while.",
            "command": "just",
            "type": "shell",
            "args": [
                "run-integration-tests"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
