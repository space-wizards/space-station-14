{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build (C# Dev Kit)",
            "detail": "Builds the game. This needs the C# Dev Kit extention to run. Use the (build) task instead if you don't have this extention (e.g. if you are using Resharper instead).",
            "type": "dotnet",
            "task": "build",
            "icon": {
                "id": "build",
                "color": "terminal.ansiBlue"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile",
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "build",
            "detail": "Builds the game. This requires Just. Use (build (C# Dev Kit)) if you are using the C# Dev Kit extension for VS Code.",
            "command": "just",
            "type": "shell",
            "args": [
                "build"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile",
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "build-yaml-linter",
            "detail": "Builds the YAML Linter. This requires Just.",
            "command": "just",
            "type": "process",
            "args": [
                "build-yaml-linter"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "just",
            "detail": "Runs all unit tests. This requires Just.",
            "type": "shell",
            "args": [
                "run-tests"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "integration-test",
            "detail": "Runs all integration tests. This requires Just. These tests take a while.",
            "command": "just",
            "type": "shell",
            "args": [
                "run-integration-tests"
            ],
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
