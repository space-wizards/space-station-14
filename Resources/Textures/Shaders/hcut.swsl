light_mode unshaded;

const highp float Cutoff = 0.3;
const highp float AlphaModifier = 0.2;
const bool KeepUpperHalf = true;

void fragment() {
    highp vec4 textureColor = zTexture(UV);
    bool keepFullAlpha = KeepUpperHalf ? UV.y > Cutoff : UV.y <= Cutoff;
    highp float alphaScale = keepFullAlpha ? 1.0 : AlphaModifier;

    COLOR = vec4(textureColor.rgb, textureColor.a * alphaScale);
}
