uniform sampler2D SCREEN_TEXTURE;
// Strength of the rainbow color effect. Between 0 and 1.
uniform highp float colorScale;
// Strength of the screen warping effect. Between 0 and 1.
uniform highp float warpScale;
// How fast to do the rotating motion.
// 1 for the normal effect.
// 0 for the reduced motion setting.
uniform highp float timeScale;
// Starting phase for the rotation effect.
// Needed so it does not always look the same for 0 motion.
uniform highp float phase;

const highp float DistortionScale = 0.02; // How strongly to warp the screen.
const highp float NoiseScale = 4.0; // Scale of the random noise.
const highp float MaxColorMix = 0.05; // At 1.0, you would barely see the screen anymore.
const highp float BaseColorMult = 8.0; // Scales the source color before the rainbow mix.
const highp float BaseColorPow = 0.8; // Exponent applied to the rainbow mask.
const highp float CenterRadius = 200.0; // Distortion falloff radius.
const highp float CenterMinDist = 0.4; // Distortion minimum center distance.
const highp float CenterPow = 3.0; // Distortion center exponent.
const highp float CenterColorRadius = 250.0; // Color falloff radius.
const highp float CenterColorMinDist = 0.2; // Color minimum center distance.
const highp float CenterColorPow = 1.25; // Color center exponent.

// noise() and hsv2rgb_smooth() were converted from shadertoy examples, which
// were released under the MIT License:
// The MIT License
// Copyright (c) 2013 Inigo Quilez
