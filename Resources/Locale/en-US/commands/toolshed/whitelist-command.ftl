command-description-whitelist-add = Adds the player with the given username to the server whitelist.
cmd-whitelistadd-existing = {$username} is already on the whitelist!
cmd-whitelistadd-added = {$username} added to the whitelist

command-description-whitelist-remove = Removes the player with the given username from the server whitelist.
cmd-whitelistremove-existing = {$username} is not on the whitelist!
cmd-whitelistremove-removed = {$username} removed from the whitelist

command-description-whitelist-kickNonWhitelisted = Kicks all non-whitelisted players from the server.

command-whitelist-not-found = Unable to find '{$username}'!
