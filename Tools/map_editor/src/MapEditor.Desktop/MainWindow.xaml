<Window x:Class="MapEditor.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MapEditor.Desktop"
        Title="SS14 Map Editor (Experimental)"
        Height="720" Width="1280"
        Background="#0f0f14">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#1a1a2e" Foreground="#cfcfe0">
            <MenuItem Header="_File" Foreground="#cfcfe0" Background="#1a1a2e">
                <MenuItem x:Name="OpenMapMenuItem" Header="_Open Map..." Click="OnOpenMapClick" />
                <Separator />
                <MenuItem x:Name="ExitMenuItem" Header="E_xit" Click="OnExitClick" />
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#1a1a2e" BorderBrush="#2a2a3e" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Foreground="#cfcfe0" FontSize="14" FontWeight="SemiBold" Text="SS14 Map Editor" />
                        <TextBlock Foreground="#7a7a8e" FontSize="11" Margin="0,4,0,0" Text="Experimental RT embedded host" />
                        <TextBlock x:Name="StatusText"
                                   Foreground="#7a7a8e" FontSize="11"
                                   Margin="0,8,0,8" TextWrapping="Wrap"
                                   Text="Waiting for RT..." />
                        <CheckBox x:Name="LightingCheckBox"
                                  Content="Enable lighting"
                                  Foreground="#cfcfe0"
                                  Margin="0,0,0,4"
                                  Click="OnLightingToggle" />
                        <Button x:Name="RunBenchmarkButton"
                                Content="Run render benchmark"
                                Background="#2a2a3e" Foreground="#cfcfe0"
                                BorderBrush="#3a3a4e" BorderThickness="1"
                                Padding="6,4" Margin="0,0,0,4"
                                HorizontalAlignment="Stretch"
                                Click="OnRunBenchmarkClick" />
                        <TextBlock x:Name="BenchmarkResultText"
                                   Foreground="#a0e0a0" FontFamily="Consolas"
                                   FontSize="9"
                                   Margin="0,0,0,8" TextWrapping="NoWrap"
                                   Text="" />
                        <TextBlock Foreground="#cfcfe0" FontSize="12" FontWeight="SemiBold"
                                   Margin="0,8,0,4" Text="Entity Palette" />
                        <TextBox x:Name="EntitySearchBox"
                                 Background="#0f0f14" Foreground="#cfcfe0"
                                 BorderBrush="#2a2a3e" BorderThickness="1"
                                 Padding="4,2"
                                 TextChanged="OnEntitySearchChanged" />
                        <TextBlock x:Name="SelectedEntityText"
                                   Foreground="#8be9fd" FontSize="10"
                                   Margin="0,4,0,4" TextWrapping="Wrap"
                                   Text="None selected" />
                        <TextBlock Foreground="#4a4a5e" FontSize="9"
                                   Margin="0,0,0,4" TextWrapping="Wrap"
                                   Text="Click an entity, then left click in the viewport to place. Right click drag to pan, scroll wheel to zoom." />
                    </StackPanel>
                    <ListBox x:Name="EntityListBox"
                             Background="#0f0f14" Foreground="#cfcfe0"
                             BorderBrush="#2a2a3e" BorderThickness="1"
                             SelectionChanged="OnEntitySelectionChanged" />
                </DockPanel>
            </Border>
            <local:RtHwndHost x:Name="RtViewport" Grid.Column="1" />
        </Grid>
    </DockPanel>
</Window>
